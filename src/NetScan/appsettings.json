{
  "Logging": {
    "LogLevel": {
      "Default": "Warning",
      "NetScan": "Information"
    },
    "Console": {
      "FormatterName": "simple",
      "FormatterOptions": {
        "TimestampFormat": "yyyy-MM-dd HH:mm:ss ",
        "SingleLine": true
      }
    }
  },
  "Monitoring": {
    "EventScanIntervalMs": 100,
    "FilterByUser": null,
    "FilterByProtocol": null,
    "FilterByProcess": null,
    "ExportFormat": null,
    "ExportPath": "./netscan_export",
    "LiveMode": true,
    "IncludeIPv6": false,
    "IncludeLoopback": true,
    "UseEbpf": false,
    "MaxDisplayRows": 100,
    "MaxEventLogRows": 15
  }
}
